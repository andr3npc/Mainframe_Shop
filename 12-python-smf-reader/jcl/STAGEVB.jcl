//            DCB=(RECFM=U,BLKSIZE=32760)
//SYSUT2   DD PATH='/z/andre/smf30.bin',
//            PATHOPTS=(OWRONLY,OCREAT,OTRUNC),
//            PATHMODE=(SIRUSR,SIWUSR,SIRGRP),
//            FILEDATA=BINARY
